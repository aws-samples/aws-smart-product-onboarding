{
  "name": "amzn-smart-product-onboarding-product-categorization",
  "root": "packages/smart-product-onboarding/product-categorization",
  "tags": ["python"],
  "targets": {
    "install": {
      "dependsOn": ["^install"],
      "executor": "nx:run-commands",
      "options": {
        "command": "uv sync",
        "cwd": "packages/smart-product-onboarding/product-categorization"
      }
    },
    "update": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv lock --upgrade",
        "cwd": "packages/smart-product-onboarding/product-categorization"
      }
    },
    "test": {
      "dependsOn": [
        "amzn-smart-product-onboarding-api-python-runtime:generate"
      ],
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run pytest",
        "cwd": "packages/smart-product-onboarding/product-categorization"
      }
    },
    "package": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'Package completed via build target'",
        "cwd": "packages/smart-product-onboarding/product-categorization"
      }
    },
    "build": {
      "dependsOn": [
        "test",
        "amzn-smart-product-onboarding-api-python-runtime:generate"
      ],
      "executor": "nx:run-commands",
      "options": {
        "command": "uv build",
        "cwd": "packages/smart-product-onboarding/product-categorization",
        "outputs": ["{projectRoot}/dist"]
      }
    },
    "publish": {
      "dependsOn": ["package"],
      "executor": "nx:run-commands",
      "options": {
        "command": "uv publish",
        "cwd": "packages/smart-product-onboarding/product-categorization"
      }
    },
    "publish:test": {
      "dependsOn": ["package"],
      "executor": "nx:run-commands",
      "options": {
        "command": "uv publish --publish-url https://test.pypi.org/legacy/",
        "cwd": "packages/smart-product-onboarding/product-categorization"
      }
    }
  },
  "implicitDependencies": ["amzn-smart-product-onboarding-core-utils"]
}
