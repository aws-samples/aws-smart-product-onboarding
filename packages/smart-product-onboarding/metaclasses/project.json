{
  "name": "amzn-smart-product-onboarding-metaclasses",
  "root": "packages/smart-product-onboarding/metaclasses",
  "tags": ["python"],
  "targets": {
    "install": {
      "dependsOn": ["^install"],
      "executor": "nx:run-commands",
      "options": {
        "command": "uv sync",
        "cwd": "packages/smart-product-onboarding"
      }
    },
    "update": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv lock --upgrade",
        "cwd": "packages/smart-product-onboarding"
      }
    },
    "test": {
      "dependsOn": [
        "install",
        "amzn-smart-product-onboarding-api-python-runtime:generate"
      ],
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run --package amzn-smart-product-onboarding-metaclasses pytest metaclasses/tests/",
        "cwd": "packages/smart-product-onboarding"
      },
      "inputs": [
        "{projectRoot}/**/*.py",
        "{projectRoot}/pyproject.toml",
        "{workspaceRoot}/packages/smart-product-onboarding/uv.lock",
        "!{projectRoot}/dist/**/*"
      ],
      "outputs": ["{projectRoot}/.pytest_cache"]
    },
    "package": {
      "dependsOn": [
        "install",
        "amzn-smart-product-onboarding-api-python-runtime:generate"
      ],
      "executor": "nx:run-commands",
      "options": {
        "command": "uv build --package amzn-smart-product-onboarding-metaclasses",
        "cwd": "packages/smart-product-onboarding"
      },
      "inputs": [
        "{projectRoot}/**/*.py",
        "{projectRoot}/pyproject.toml",
        "{workspaceRoot}/packages/smart-product-onboarding/uv.lock",
        "!{projectRoot}/dist/**/*"
      ],
      "outputs": ["{projectRoot}/dist"]
    },
    "build": {
      "dependsOn": ["test", "package"],
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'Build completed successfully'",
        "cwd": "packages/smart-product-onboarding/metaclasses"
      }
    },
    "publish:test": {
      "dependsOn": ["package"],
      "executor": "nx:run-commands",
      "options": {
        "command": "uv publish --publish-url https://test.pypi.org/legacy/ dist/*",
        "cwd": "packages/smart-product-onboarding/metaclasses"
      }
    },
    "publish": {
      "dependsOn": ["package"],
      "executor": "nx:run-commands",
      "options": {
        "command": "uv publish dist/*",
        "cwd": "packages/smart-product-onboarding/metaclasses"
      }
    }
  },
  "implicitDependencies": ["amzn-smart-product-onboarding-core-utils"]
}
