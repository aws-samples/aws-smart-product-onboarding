{
  "name": "amzn-smart-product-onboarding-core-utils",
  "root": "packages/smart-product-onboarding/core-utils",
  "tags": ["python"],
  "targets": {
    "install": {
      "dependsOn": ["^install"],
      "executor": "nx:run-commands",
      "options": {
        "command": "uv sync",
        "cwd": "packages/smart-product-onboarding/core-utils"
      }
    },
    "update": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv lock --upgrade",
        "cwd": "packages/smart-product-onboarding/core-utils"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run pytest",
        "cwd": "packages/smart-product-onboarding/core-utils"
      }
    },
    "package": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'Package completed via build target'",
        "cwd": "packages/smart-product-onboarding/core-utils"
      }
    },
    "build": {
      "dependsOn": ["test"],
      "executor": "nx:run-commands",
      "options": {
        "command": "uv build",
        "cwd": "packages/smart-product-onboarding/core-utils",
        "outputs": ["{projectRoot}/dist"]
      }
    },
    "publish": {
      "dependsOn": ["package"],
      "executor": "nx:run-commands",
      "options": {
        "command": "uv publish",
        "cwd": "packages/smart-product-onboarding/core-utils"
      }
    },
    "publish:test": {
      "dependsOn": ["package"],
      "executor": "nx:run-commands",
      "options": {
        "command": "uv publish --publish-url https://test.pypi.org/legacy/",
        "cwd": "packages/smart-product-onboarding/core-utils"
      }
    }
  }
}
